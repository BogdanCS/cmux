#!/usr/bin/env python3
"""
cmux copilot PTY helper.

Spawns a child process inside a pseudo-terminal, tees its output to stdout,
and fires `cmux notify` when the child has been silent (no new output) for
IDLE_THRESHOLD seconds — the reliable signal that it is waiting for input,
regardless of what the TUI looks like (menus, prompts, highlighted selections).

Usage: copilot-pty-helper <cmux_bin> <child_argv...>

The parent bash wrapper (Resources/bin/copilot) calls this via:
    exec python3 /path/to/copilot-pty-helper "$CMUX_BIN" "$REAL_COPILOT" "$@"

Using `exec` is essential: it hands the real TTY stdin to this process, so the
child sees proper interactive input. Running via a heredoc (python3 - <<'EOF')
would replace stdin with a pipe and break all interactivity.
"""

from __future__ import annotations

import fcntl
import os
import pty
import select
import signal
import subprocess
import sys
import termios
import time
import tty

# Seconds of output silence after which we conclude the child is waiting for input.
# 350 ms is long enough not to fire mid-stream during a fast response, and short
# enough to feel immediate when a real prompt appears.
_IDLE_THRESHOLD: float = float(os.environ.get("CMUX_COPILOT_IDLE_THRESHOLD", "0.35"))

# How long the child must have produced at least some output before idle detection
# kicks in — avoids firing a notification during the child's own startup silence.
# 1 byte is sufficient: any output at all means the child has started up.
_MIN_OUTPUT_BEFORE_IDLE: int = 1


def _sync_winsize(src: int, dst: int) -> None:
    try:
        packed = fcntl.ioctl(src, termios.TIOCGWINSZ, b"\x00" * 8)
        fcntl.ioctl(dst, termios.TIOCSWINSZ, packed)
    except OSError:
        pass


def _exit_code(raw_status: int) -> int:
    if hasattr(os, "waitstatus_to_exitcode"):
        return os.waitstatus_to_exitcode(raw_status)
    sig = raw_status & 0x7F
    return (128 + sig) if sig else ((raw_status >> 8) & 0xFF)


def run(cmux_bin: str, child_argv: list[str]) -> None:
    notify_title = os.environ.get("CMUX_COPILOT_NOTIFY_TITLE", "Copilot")
    notify_body = os.environ.get("CMUX_COPILOT_NOTIFY_BODY", "Waiting for your input")

    def fire_notify() -> None:
        try:
            subprocess.Popen(
                [cmux_bin, "notify", "--title", notify_title, "--body", notify_body],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                close_fds=True,
            )
        except Exception:
            pass

    # Fork child into a new PTY. pty.fork() handles setsid + TIOCSCTTY +
    # dup2(slave, 0/1/2) so the child has a proper controlling terminal.
    try:
        pid, master_fd = pty.fork()
    except OSError:
        # No PTY available — exec child directly (no notification).
        os.execvp(child_argv[0], child_argv)
        sys.exit(127)

    if pid == 0:  # child
        try:
            os.execvp(child_argv[0], child_argv)
        except Exception:
            pass
        os._exit(127)

    # ---- parent ----
    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()
    # Only engage raw mode and stdin forwarding when stdin is a real TTY.
    # When not a TTY (pipes, tests) we still capture child output correctly;
    # we just don't forward keystrokes.
    stdin_is_tty = os.isatty(stdin_fd)

    old_attr: list | None = None
    if stdin_is_tty:
        try:
            old_attr = termios.tcgetattr(stdin_fd)
            tty.setraw(stdin_fd)
            _sync_winsize(stdin_fd, master_fd)
        except termios.error:
            old_attr = None

    def _handle_winch(sig: int, frame: object) -> None:
        _sync_winsize(stdin_fd, master_fd)

    if stdin_is_tty:
        signal.signal(signal.SIGWINCH, _handle_winch)

    total_output: int = 0     # total bytes received from child
    last_output_at: float = 0.0  # monotonic time of last received byte
    notified: bool = False

    # select() timeout: poll frequently enough to detect the idle threshold.
    _SELECT_TIMEOUT = min(0.05, _IDLE_THRESHOLD / 4)

    try:
        while True:
            watch = [master_fd]
            if stdin_is_tty:
                watch.append(stdin_fd)

            try:
                rfds, _, _ = select.select(watch, [], [], _SELECT_TIMEOUT)
            except (OSError, ValueError, select.error):
                break

            if master_fd in rfds:
                try:
                    data = os.read(master_fd, 4096)
                except OSError:
                    break
                if not data:
                    break
                total_output += len(data)
                last_output_at = time.monotonic()
                # Do NOT reset notified here. PTY echo of the user's keystrokes
                # arrives on master_fd too — resetting here would re-fire the
                # notification on every typing pause while the user composes
                # their reply. notified only resets when the user submits (Enter).
                try:
                    os.write(stdout_fd, data)
                except OSError:
                    break

            if stdin_is_tty and stdin_fd in rfds:
                try:
                    data = os.read(stdin_fd, 1024)
                except OSError:
                    break
                if not data:
                    break
                # Reset notification state only when the user submits their
                # response (presses Enter / Return). This lets the next idle
                # period — when copilot finishes generating and waits again —
                # trigger a fresh notification, while suppressing re-fires
                # during the typing of the current reply.
                if b"\r" in data or b"\n" in data:
                    notified = False
                    last_output_at = 0.0
                try:
                    os.write(master_fd, data)
                except OSError:
                    break

            # Idle check: fire notify if child has been quiet for IDLE_THRESHOLD.
            if (
                not notified
                and total_output >= _MIN_OUTPUT_BEFORE_IDLE
                and last_output_at > 0.0
                and (time.monotonic() - last_output_at) >= _IDLE_THRESHOLD
            ):
                notified = True
                fire_notify()

    finally:
        if old_attr is not None:
            try:
                termios.tcsetattr(stdin_fd, termios.TCSAFLUSH, old_attr)
            except termios.error:
                pass
        if stdin_is_tty:
            signal.signal(signal.SIGWINCH, signal.SIG_DFL)
        try:
            os.close(master_fd)
        except OSError:
            pass

    _, raw_status = os.waitpid(pid, 0)
    sys.exit(_exit_code(raw_status))


if __name__ == "__main__":
    if len(sys.argv) < 3:
        print(
            f"Usage: {sys.argv[0]} <cmux_bin> <child_argv...>",
            file=sys.stderr,
        )
        sys.exit(1)
    run(cmux_bin=sys.argv[1], child_argv=sys.argv[2:])
